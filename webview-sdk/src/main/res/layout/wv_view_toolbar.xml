<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wvToolbarRoot"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="?attr/colorSurface">

    <ImageButton
        android:id="@+id/wvBtnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/wv_ic_arrow_back"
        android:contentDescription="@string/wv_back"
        android:scaleType="centerInside" />

    <ImageButton
        android:id="@+id/wvBtnClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="56dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/wv_ic_close"
        android:contentDescription="@string/wv_close"
        android:scaleType="centerInside" />

    <TextView
        android:id="@+id/wvTvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:maxLines="1"
        android:ellipsize="end" />

    <ImageButton
        android:id="@+id/wvBtnRight"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@null"
        android:scaleType="centerInside"
        android:visibility="gone" />

    <View
        android:id="@+id/wvDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:background="?attr/colorOnSurface"
        android:alpha="0.1"
        android:visibility="gone" />

</FrameLayout>
